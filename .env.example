# ============================================================
# BOTFILTA AI — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ------------------------------------------------------------
# SUPABASE (required for all data persistence)
# Get these from: https://supabase.com → Project Settings → API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# WHATSAPP CLOUD API (required for sending/receiving messages)
# Get these from: https://developers.facebook.com → WhatsApp → Getting Started
# ------------------------------------------------------------
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_SECRET=

# ------------------------------------------------------------
# GOOGLE GEMINI AI (required for AI auto-reply)
# Get this from: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=

# ------------------------------------------------------------
# APP CONFIG
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:5000
